.filter(function(r){return r.impressions>=100;});var _aa=_wi.map(_ctr).sort(function(x,y){return x-y;});var _med=_aa.length?_aa[Math.floor(_aa.length/2)]:0;ctx.creativeBenchmark={medianImageCtr:Number(_med.toFixed(2)),imageCount:_im.length,note:"Google ratings are often PENDING so weak images must be judged by metrics not ratings"};ctx.underperformingCreatives=_wi.map(function(r){return {asset:r.name||r.text||"asset",account:r.account,impressions:r.impressions,clicks:r.clicks,ctr:Number(_ctr(r).toFixed(2)),conversions:Math.round(r.conversions||0),spend:Number(((r.costMicros||0)/1e6).toFixed(2)),aspect:(r.imageW&&r.imageH)?(r.imageW+"x"+r.imageH):"",reason:(r.clicks>0&&(r.conversions||0)<1)?"clicks but no conversions":(_ctr(r)<_med?"below median CTR":"low engagement")};}).filter(function(o){return o.ctr<_med||(o.clicks>0&&o.conversions<1);}).sort(function(x,y){return y.impressions-x.impressions;}).slice(0,12);ctx.lowRatedCreatives=ctx.underperformingCreatives;}return JSON.stringify(ctx);}',
'function aiMarkdown(s){if(!s)return "";s=s.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");s=s.replace(/\\*\\*([^*]+)\\*\\*/g,"<b>$1</b>");s=s.replace(/`([^`]+)`/g,"<code>$1</code>");s=s.replace(/^### (.+)$/gm,"<h4>$1</h4>");s=s.replace(/^## (.+)$/gm,"<h3>$1</h3>");s=s.replace(/^# (.+)$/gm,"<h3>$1</h3>");var lines=s.split("\\n");var out="";var inList=false;for(var i=0;i<lines.length;i++){var ln=lines[i].trim();if(/^[-*]\\s+/.test(ln)){if(!inList){out+="<ul>";inList=true;}out+="<li>"+ln.replace(/^[-*]\\s+/,"")+"</li>";}else if(/^\\d+\\.\\s+/.test(ln)){if(!inList){out+="<ul>";inList=true;}out+="<li>"+ln.replace(/^\\d+\\.\\s+/,"")+"</li>";}else{if(inList){out+="</ul>";inList=false;}if(ln.indexOf("<h")===0)out+=ln;else if(ln)out+="<p>"+ln+"</p>";}}if(inList)out+="</ul>";return out;}',
