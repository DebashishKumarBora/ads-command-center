'function ovEnsureTrend(){var v=document.getElementById("ovAcct").value;var cid="";if(v){var ac=allData.find(function(a){return a.name===v;});if(ac)cid=String(ac.id);}var key=range+"|"+customStart+"|"+customEnd+"|"+cid;if(ovTrendKey===key&&ovTrend){return;}ovTrendKey=key;ovTrend=null;ovHeroLoading(true,"Loading daily trend...");google.script.run.withSuccessHandler(function(res){if(!res||res.error){ovTrend={series:[],cur:null,prev:null,err:(res&&res.error)||"no data"};}else{ovTrend=res;}ovApplyTrend();ovApplyDeltas();}).withFailureHandler(function(e){ovTrend={series:[],cur:null,prev:null,err:e.message};ovApplyTrend();ovApplyDeltas();}).getOverviewTrend(range,customStart,customEnd,cid);}',
'function ovApplyTrend(){var d=getOvData();var t=totals(d);ovSetHero(t);var de=document.getElementById("ov-hero-delta");if(de){if(ovTrend&&ovTrend.cur&&ovTrend.prev){var m=ovHeroMetric;var cV=m=="spend"?ovTrend.cur.spend:m=="clicks"?ovTrend.cur.clicks:ovTrend.cur.conv;var pV=m=="spend"?ovTrend.prev.spend:m=="clicks"?ovTrend.prev.clicks:ovTrend.prev.conv;de.innerHTML=ovDeltaHtml(cV,pV)+" <span class=\\"ov-hero-vs\\">vs previous "+ovRangeLen()+"</span>";}else{de.innerHTML="";}}var series=(ovTrend&&ovTrend.series)?ovTrend.series:[];if(!series.length){if(charts["ov-hero-canvas"]){charts["ov-hero-canvas"].destroy();delete charts["ov-hero-canvas"];}ovHeroLoading(true,(ovTrend&&ovTrend.err)?"Daily trend unavailable right now":(ovTrend?"No daily data for this range":"Loading daily trend..."));return;}ovHeroLoading(false);var key=ovHeroMetric;var labels=series.map(function(p){return p.date.slice(5);});var vals=series.map(function(p){return key=="spend"?p.spend/1e6:key=="clicks"?p.clicks:p.conv;});var hex=key=="spend"?"#4d8dff":key=="clicks"?"#38d9f5":"#22d39a";mkArea("ov-hero-canvas",labels,vals,hex,function(v){return key=="spend"?usd(v*1e6):fmt(Math.round(v));});}',
'function ovApplyDeltas(){if(!ovTrend)return;var cur=ovTrend.cur,prev=ovTrend.prev,series=ovTrend.series||[];function sd(id,c,p){var e=document.getElementById(id);if(e)e.innerHTML=(cur&&prev)?ovDeltaHtml(c,p):"";}function ss(id,key,hex){var e=document.getElementById(id);if(e)e.innerHTML=ovSpark(series,key,hex);}if(cur&&prev){sd("ov-d-spend",cur.spend,prev.spend);sd("ov-d-impr",cur.impr,prev.impr);sd("ov-d-clicks",cur.clicks,prev.clicks);sd("ov-d-conv",cur.conv,prev.conv);}ss("ov-sp-spend","spend","#4d8dff");ss("ov-sp-impr","impr","#7b5cff");ss("ov-sp-clicks","clicks","#38d9f5");ss("ov-sp-conv","conv","#22d39a");}',
