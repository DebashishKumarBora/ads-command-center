'function aiAddRow(role){var b=document.getElementById("chatBody");var em=b.querySelector(".chat-empty");if(em)b.innerHTML="";var row=document.createElement("div");row.className="chat-row "+role;var ava=document.createElement("div");ava.className="chat-ava "+role;ava.innerHTML=(role==="ai")?"<svg viewBox=\\"0 0 24 24\\"><path d=\\"M12 3l1.9 5.8L20 9.7l-4.7 3.5L17 19l-5-3.4L7 19l1.7-5.8L4 9.7l6.1-.9z\\"/></svg>":"<svg viewBox=\\"0 0 24 24\\"><circle cx=\\"12\\" cy=\\"8\\" r=\\"4\\"/><path d=\\"M4 21v-1a7 7 0 0 1 16 0v1\\"/></svg>";var col=document.createElement("div");col.className="chat-col";col.style.maxWidth="84%";var bubble=document.createElement("div");bubble.className="chat-msg";col.appendChild(bubble);row.appendChild(ava);row.appendChild(col);b.appendChild(row);return {row:row,col:col,bubble:bubble};}',
