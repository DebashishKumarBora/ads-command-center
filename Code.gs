function getSearchTermsData(range, cs, ce) {
  range = range || '30'; var token = getAccessToken(); var dc = dateClause(range, cs, ce);
  var accountsRaw = adsQuery(MANAGER_ID, 'SELECT customer_client.id, customer_client.descriptive_name, customer_client.status, customer_client.manager FROM customer_client', token);
  var accounts = accountsRaw.map(function(r){ return r.customerClient; }).filter(function(c){ return c.status === 'ENABLED' && !c.manager; });
  var allTerms = [];
  accounts.forEach(function(acct) { try {
    var results = adsQuery(acct.id, 'SELECT search_term_view.search_term, search_term_view.status, campaign.name, metrics.impressions, metrics.clicks, metrics.cost_micros, metrics.conversions, metrics.ctr FROM search_term_view WHERE ' + dc + ' ORDER BY metrics.cost_micros DESC LIMIT 40', token);
    results.forEach(function(r) { var stv=r.searchTermView||{}, m=r.metrics||{}; allTerms.push({ term:stv.searchTerm||'', status:stv.status||'NONE', campaign:r.campaign?r.campaign.name:'', account:acct.descriptiveName, accountId:String(acct.id), impressions:Number(m.impressions||0), clicks:Number(m.clicks||0), costMicros:Number(m.costMicros||0), conversions:Number(m.conversions||0), ctr:Number(m.ctr||0) }); });
  } catch(e){} });
  allTerms.sort(function(a,b){ return b.costMicros-a.costMicros; });
  return { terms: allTerms, timestamp: new Date().toISOString() };
}
 
