'function aiStripForSpeech(s){if(!s)return "";s=s.replace(/___FOLLOWUPS___[\\s\\S]*$/,"");s=s.replace(/```[\\s\\S]*?```/g," ");s=s.replace(/`([^`]+)`/g,"$1");s=s.replace(/\\*\\*([^*]+)\\*\\*/g,"$1");s=s.replace(/^\\s*[-*]\\s+/gm,"");s=s.replace(/[*_#>]/g," ");s=s.replace(/\\n+/g,". ");s=s.replace(/\\s+/g," ");return s.trim();}',
