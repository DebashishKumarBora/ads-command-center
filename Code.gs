'function kpiX(l,v,s,icon,did,sid){var delta=did?("<span class=\\"kpi-delta-chip flat\\" id=\\""+did+"\\"></span>"):"";var spark=sid?("<div class=\\"kpi-spark\\" id=\\""+sid+"\\"></div>"):"";return "<div class=\\"kpi lux\\"><div class=\\"kpi-top\\"><span class=\\"kpi-label\\">"+l+"</span><span class=\\"kpi-ic\\"><svg viewBox=\\"0 0 24 24\\">"+icon+"</svg></span></div><div class=\\"kpi-val num\\">"+v+"</div><div class=\\"kpi-foot\\"><span class=\\"kpi-sub\\">"+s+"</span>"+delta+"</div>"+spark+"</div>";}',
'function ovDeltaHtml(cur,prev){if(prev<=0)return "<span class=\\"kpi-delta-chip flat\\">new</span>";var t=(cur-prev)/prev*100;var up=t>=0;return "<span class=\\"kpi-delta-chip "+(up?"up":"down")+"\\">"+(up?"\\u25b2":"\\u25bc")+" "+Math.abs(t).toFixed(1)+"%</span>";}',
'function ovSpark(series,key,hex){if(!series||series.length<2)return "";var vals=series.map(function(p){return key=="spend"?p.spend:key=="clicks"?p.clicks:key=="conv"?p.conv:p.impr;});var mn=Math.min.apply(null,vals),mx=Math.max.apply(null,vals);var n=vals.length;var pts=vals.map(function(v,i){var x=(i/(n-1))*100;var y=28-((mx>mn)?((v-mn)/(mx-mn)):0.5)*24-2;return x.toFixed(1)+","+y.toFixed(1);}).join(" ");var last=vals[n-1];var ly=28-((mx>mn)?((last-mn)/(mx-mn)):0.5)*24-2;return "<svg viewBox=\\"0 0 100 30\\" preserveAspectRatio=\\"none\\" style=\\"width:100%;height:30px;\\"><polyline points=\\""+pts+"\\" fill=\\"none\\" stroke=\\""+hex+"\\" stroke-width=\\"2\\" stroke-linejoin=\\"round\\" stroke-linecap=\\"round\\" vector-effect=\\"non-scaling-stroke\\"/><circle cx=\\"100\\" cy=\\""+ly.toFixed(1)+"\\" r=\\"2.3\\" fill=\\""+hex+"\\"/></svg>";}',
'function mkArea(id,labels,data,hex,fmtFn){if(charts[id])charts[id].destroy();var ctx=document.getElementById(id);if(!ctx)return;var g=ctx.getContext("2d");if(!g){return;}var grad=g.createLinearGradient(0,0,0,190);grad.addColorStop(0,hex+"59");grad.addColorStop(1,hex+"00");charts[id]=new Chart(ctx,{type:"line",data:{labels:labels,datasets:[{data:data,borderColor:hex,borderWidth:2.5,backgroundColor:grad,fill:true,tension:0.4,pointRadius:0,pointHoverRadius:5,pointHoverBackgroundColor:hex,pointHoverBorderColor:"#fff",pointHoverBorderWidth:2}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{backgroundColor:cv("--surface2"),titleColor:cv("--text"),bodyColor:cv("--muted2"),borderColor:cv("--border2"),borderWidth:1,padding:10,displayColors:false,callbacks:{label:function(c){return fmtFn?fmtFn(c.parsed.y):c.parsed.y;}}}},scales:{x:{ticks:{color:cv("--muted"),font:{size:9,family:"JetBrains Mono"},maxTicksLimit:8},grid:{display:false}},y:{ticks:{color:cv("--muted"),font:{size:9,family:"JetBrains Mono"},maxTicksLimit:5},grid:{color:cv("--grid")}}}}});}',
'function ovSetHero(t){var m=ovHeroMetric;var val,lab;if(m=="spend"){val=usd(t.s);lab="PORTFOLIO SPEND";}else if(m=="clicks"){val=fmt(t.c);lab="TOTAL CLICKS";}else{val=fmt(Math.round(t.cv));lab="TOTAL CONVERSIONS";}var ve=document.getElementById("ov-hero-val");if(ve)ve.textContent=val;var le=document.getElementById("ov-hero-label");if(le)le.textContent=lab;var re=document.getElementById("ov-hero-range");if(re)re.textContent=ovRangeLabel();var up=document.getElementById("ov-hero-updated");if(up)up.textContent=lastTs?new Date(lastTs).toLocaleTimeString([],{hour:"numeric",minute:"2-digit"}):"just now";}',
