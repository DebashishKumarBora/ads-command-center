function getAdGroupData(range, cs, ce) { range = range || '30'; var token = getAccessToken(); var dc = dateClause(range, cs, ce); var accountsRaw = adsQuery(MANAGER_ID, 'SELECT customer_client.id, customer_client.descriptive_name, customer_client.status, customer_client.manager FROM customer_client', token); var accounts = accountsRaw.map(function(r){ return r.customerClient; }).filter(function(c){ return c.status === 'ENABLED' && !c.manager; }); var all = []; accounts.forEach(function(acct) { try { var results = adsQuery(acct.id, "SELECT campaign.name, ad_group.name, ad_group.status, metrics.impressions, metrics.clicks, metrics.cost_micros, metrics.conversions, metrics.ctr FROM ad_group WHERE " + dc + " AND ad_group.status != 'REMOVED' ORDER BY metrics.cost_micros DESC LIMIT 50", token); results.forEach(function(r) { var ag=r.adGroup||{}, m=r.metrics||{}; all.push({ name:ag.name||'', status:ag.status||'', campaign:r.campaign?r.campaign.name:'', account:acct.descriptiveName, accountId:String(acct.id), impressions:Number(m.impressions||0), clicks:Number(m.clicks||0), costMicros:Number(m.costMicros||0), conversions:Number(m.conversions||0), ctr:Number(m.ctr||0) }); }); } catch(e){} }); all.sort(function(a,b){ return b.costMicros-a.costMicros; }); return { groups: all, timestamp: new Date().toISOString() }; }
 
function getAccountAdGroups(accountId, range, cs, ce) { range = range || '30'; var token = getAccessToken(); var dc = dateClause(range, cs, ce); var all = []; var err=null; try { var results = adsQuery(accountId, "SELECT ad_group.name, ad_group.status, campaign.name, metrics.impressions, metrics.clicks, metrics.cost_micros, metrics.conversions, metrics.ctr FROM ad_group WHERE " + dc + " ORDER BY metrics.cost_micros DESC LIMIT 50", token); results.forEach(function(r) { var ag=r.adGroup||{}, m=r.metrics||{}; all.push({ name:ag.name||'', status:ag.status||'', campaign:r.campaign?r.campaign.name:'', impressions:Number(m.impressions||0), clicks:Number(m.clicks||0), costMicros:Number(m.costMicros||0), conversions:Number(m.conversions||0), ctr:Number(m.ctr||0) }); }); } catch(e){ err=e.message; } return { groups: all, error: err, timestamp: new Date().toISOString() }; }
 
function getTimeOfDayData(range, cs, ce) { range = range || '30'; var token = getAccessToken(); var dc = dateClause(range, cs, ce); var accountsRaw = adsQuery(MANAGER_ID, 'SELECT customer_client.id, customer_client.descriptive_name, customer_client.status, customer_client.manager FROM customer_client', token); var accounts = accountsRaw.map(function(r){ return r.customerClient; }).filter(function(c){ return c.status === 'ENABLED' && !c.manager; }); var cells = {}; accounts.forEach(function(acct) { try { var rows = adsQuery(acct.id, "SELECT segments.day_of_week, segments.hour, metrics.impressions, metrics.clicks, metrics.conversions, metrics.cost_micros FROM customer WHERE " + dc, token); rows.forEach(function(r) { var s=r.segments||{}, m=r.metrics||{}; var k=(s.dayOfWeek||'')+'|'+(s.hour!=null?s.hour:''); if(!cells[k]) cells[k]={impr:0,clicks:0,conv:0,cost:0}; cells[k].impr+=Number(m.impressions||0); cells[k].clicks+=Number(m.clicks||0); cells[k].conv+=Number(m.conversions||0); cells[k].cost+=Number(m.costMicros||0); }); } catch(e){} }); return { cells: cells, days:['MONDAY','TUESDAY','WEDNESDAY','THURSDAY','FRIDAY','SATURDAY','SUNDAY'], timestamp: new Date().toISOString() }; }
 
function getGeoData(range, cs, ce, customerId) {
  try {
    range = range || '30'; var token = getAccessToken(); var dc = dateClause(range, cs, ce);
    var accounts;
    if (customerId) { accounts = [{ id: String(customerId), descriptiveName: '' }]; }
    else {
      var accountsRaw = adsQuery(MANAGER_ID, 'SELECT customer_client.id, customer_client.descriptive_name, customer_client.status, customer_client.manager FROM customer_client', token);
      accounts = accountsRaw.map(function(r){ return r.customerClient; }).filter(function(c){ return c.status === 'ENABLED' && !c.manager; });
    }
    var agg = {};
    accounts.forEach(function(acct){ try {
      var rows = adsQuery(acct.id, 'SELECT segments.geo_target_region, metrics.impressions, metrics.clicks, metrics.cost_micros, metrics.conversions FROM geographic_view WHERE ' + dc + ' AND metrics.impressions > 0 ORDER BY metrics.impressions DESC LIMIT 60', token);
      rows.forEach(function(r){ var seg = r.segments || {}; var reg = seg.geoTargetRegion || ''; if(!reg) return; var m = r.metrics || {};
        if(!agg[reg]) agg[reg] = { impr:0, clicks:0, conv:0, cost:0 };
        agg[reg].impr += Number(m.impressions||0); agg[reg].clicks += Number(m.clicks||0); agg[reg].conv += Number(m.conversions||0); agg[reg].cost += Number(m.costMicros||0);
      });
    } catch(e){} });
    var ids = Object.keys(agg).map(function(rn){ var p = rn.split('/'); return p[p.length-1]; }).filter(function(x){ return x; });
    var idInfo = {};
    if (ids.length) { try {
      var gr = adsQuery(MANAGER_ID, 'SELECT geo_target_constant.id, geo_target_constant.name, geo_target_constant.canonical_name, geo_target_constant.country_code, geo_target_constant.target_type FROM geo_target_constant WHERE geo_target_constant.id IN (' + ids.join(',') + ')', token);
      gr.forEach(function(r){ var g = r.geoTargetConstant || {}; idInfo[String(g.id)] = { name: g.name||'', canonical: g.canonicalName||'', country: g.countryCode||'' }; });
    } catch(e){} }
    var locations = [];
    Object.keys(agg).forEach(function(rn){
      var p = rn.split('/'); var id = p[p.length-1]; var info = idInfo[id] || {}; var a = agg[rn];
      locations.push({ id:id, name: info.name || ('Region ' + id), canonical: info.canonical || '', country: info.country || '', impressions:a.impr, clicks:a.clicks, conversions:a.conv, costMicros:a.cost });
    });
    locations.sort(function(x,y){ return y.costMicros - x.costMicros; });
    return { locations: locations, timestamp: new Date().toISOString() };
  } catch(e) { return { error: e.message }; }
}
 
 
function getOverviewTrend(range, cs, ce, customerId) {
  try {
    var token = getAccessToken();
    var end = new Date(); var start = new Date(); var len = 30;
    if (range === '7') { len = 7; } else if (range === '90') { len = 90; } else if (range === 'custom' && cs && ce) { var ds = new Date(cs + 'T00:00:00Z'); var de = new Date(ce + 'T00:00:00Z'); start = ds; end = de; len = Math.round((de - ds) / 86400000) + 1; } else { len = 30; }
    if (range !== 'custom') { end = new Date(); start = new Date(); start.setDate(end.getDate() - (len - 1)); }
    var prevStart = new Date(start); prevStart.setDate(start.getDate() - len);
    var f = function(d){ return Utilities.formatDate(d, 'GMT', 'yyyy-MM-dd'); };
    var combinedStart = f(prevStart), combinedEnd = f(end), curStart = f(start);
    var accounts;
    if (customerId) { accounts = [{ id: String(customerId) }]; }
    else {
      var accountsRaw = adsQuery(MANAGER_ID, 'SELECT customer_client.id, customer_client.status, customer_client.manager FROM customer_client', token);
      accounts = accountsRaw.map(function(r){ return r.customerClient; }).filter(function(c){ return c.status === 'ENABLED' && !c.manager; });
    }
    var byDate = {};
    accounts.forEach(function(acct){ try {
      var rows = adsQuery(acct.id, "SELECT segments.date, metrics.cost_micros, metrics.clicks, metrics.conversions, metrics.impressions FROM customer WHERE segments.date BETWEEN '" + combinedStart + "' AND '" + combinedEnd + "'", token);
      rows.forEach(function(r){ var d = (r.segments && r.segments.date) || ''; if (!d) return; var m = r.metrics || {}; if (!byDate[d]) byDate[d] = { spend:0, clicks:0, conv:0, impr:0 }; byDate[d].spend += Number(m.costMicros||0); byDate[d].clicks += Number(m.clicks||0); byDate[d].conv += Number(m.conversions||0); byDate[d].impr += Number(m.impressions||0); });
    } catch(e){} });
    var dates = Object.keys(byDate).sort();
    var series = [], prev = { spend:0, clicks:0, conv:0, impr:0 }, cur = { spend:0, clicks:0, conv:0, impr:0 };
    dates.forEach(function(d){ var o = byDate[d]; if (d >= curStart) { series.push({ date:d, spend:o.spend, clicks:o.clicks, conv:o.conv, impr:o.impr }); cur.spend+=o.spend; cur.clicks+=o.clicks; cur.conv+=o.conv; cur.impr+=o.impr; } else { prev.spend+=o.spend; prev.clicks+=o.clicks; prev.conv+=o.conv; prev.impr+=o.impr; } });
    return { series: series, cur: cur, prev: prev, timestamp: new Date().toISOString() };
  } catch(e) { return { error: e.message }; }
}
 
