const AI_SYSTEM_PROMPT = 'You are an expert Google Ads analyst for a property management company that runs ad campaigns for multiple apartment communities. You help the marketing team make fast, confident decisions. You have access to live data covering account spend, clicks, conversions, CTR, CPC, plus budget vs actual spend, occupancy rates, and vacant unit counts per property. When you analyze, focus on these four areas: (1) Budget pacing - which properties are over or under spending versus plan. (2) Occupancy-based spend - recommend MORE spend for properties with low occupancy and vacant units to fill, and LESS spend for properties near full capacity. (3) Creative performance - flag underperforming images and videos. (4) Search term waste - terms that spend without converting. Always be specific: use real property names and real numbers from the data. Keep answers concise and easy to scan. Use short sections with bold headers and bullet points. When giving a full analysis, always end with a short prioritized action list titled "Do This Week". Never invent numbers that are not in the data. If data for something is missing, say so plainly.';
 
function saveApiKey(key){try{if(!key||key.indexOf('sk-ant-')!==0)return{error:'That does not look like a valid Anthropic key. It should start with sk-ant-'};PropertiesService.getScriptProperties().setProperty('ANTHROPIC_API_KEY',key.trim());return{ok:true};}catch(e){return{error:e.message};}}
 
function getApiKeyStatus(){var k=PropertiesService.getScriptProperties().getProperty('ANTHROPIC_API_KEY');if(!k)return{set:false};return{set:true,masked:'sk-ant-...'+k.slice(-4)};}
 
function clearApiKey(){PropertiesService.getScriptProperties().deleteProperty('ANTHROPIC_API_KEY');return{ok:true};}
 
function callClaude(systemPrompt,messages,maxTokens){var apiKey=PropertiesService.getScriptProperties().getProperty('ANTHROPIC_API_KEY');if(!apiKey)return{error:'No API key set yet. Go to Settings and add your Anthropic API key.'};var payload={model:AI_MODEL,max_tokens:maxTokens||2000,system:systemPrompt,messages:messages};var options={method:'post',contentType:'application/json',headers:{'x-api-key':apiKey,'anthropic-version':'2023-06-01'},payload:JSON.stringify(payload),muteHttpExceptions:true};try{var resp=UrlFetchApp.fetch('https://api.anthropic.com/v1/messages',options);var code=resp.getResponseCode();var data=JSON.parse(resp.getContentText());if(code!==200){return{error:(data.error&&data.error.message)?data.error.message:'API error '+code};}var text='';if(data.content&&data.content.length){data.content.forEach(function(b){if(b.type==='text')text+=b.text;});}return{text:text};}catch(e){return{error:e.message};}}
 
function getAIAnalysis(mode,focus,contextJson){var struct=' You MUST respond with ONLY a valid JSON object. No markdown, no code fences, no text outside the JSON. Structure: {"healthScore":<integer 0-100>,"grade":"<A|B|C|D|F>","headline":"<punchy sentence under 90 chars>","summary":"<2 to 3 sentence executive summary>","metrics":[{"label":"<short>","value":"<formatted>","status":"<good|warn|bad>"}],"priorities":[{"severity":"<high|medium|low>","title":"<short action under 50 chars>","detail":"<1 to 2 sentences with real names and numbers, explaining WHY and exactly WHAT to do>","impact":"<expected dollar or percent impact>"}],"opportunities":[{"title":"<short>","detail":"<with numbers>"}],"wins":[{"title":"<short>","detail":"<what is working, with numbers>"}]} Provide 4 to 6 metrics, 3 to 6 priorities ordered most urgent first, 2 to 4 opportunities, 2 to 3 wins. Use only real numbers and names from the data. If a category has no data, do not invent it.';var focusNote=focus?(' SCOPE: Analyze ONLY the property named "'+focus+'". Every metric, priority, opportunity, and win must be specific to '+focus+'. The headline and healthScore are about '+focus+' specifically.'):' SCOPE: Analyze across all properties in the portfolio.';var modes={overview:'This is an OVERVIEW analysis. Cover budget pacing, occupancy-based spend, creative performance, and search term waste. healthScore reflects overall health combining spend efficiency, conversions, and budget alignment.',images:'You are analyzing IMAGE creative performance. For each LOW or underperforming image in priorities, explain in detail WHY it is likely underperforming (consider aspect ratio, subject matter, the property it belongs to) and exactly WHAT to do to fix it (what style of photography to shoot, which aspect ratio to use, what to A/B test). wins = top rated images and the concrete visual patterns worth repeating. Be specific about photography subject, composition, and format. IMPORTANT: Google performance ratings are frequently PENDING or UNRATED in this data; do NOT treat PENDING as meaningful and do NOT claim you are blind. Identify underperformers using the METRICS provided (the underperformingImages list, each images ctr versus imageBenchmark.medianCtr, images with many impressions but few clicks, and images with clicks but zero conversions). In priorities, name the specific image asset, state the exact weak metric, give a PREDICTION of the likely improvement if replaced such as expected CTR lift toward the median or projected extra leads, and give a concrete improvement spec covering what subject and composition to shoot, which aspect ratio, and what to A/B test. healthScore reflects creative health.',videos:'You are analyzing VIDEO creative performance. For each LOW or underperforming video in priorities, explain WHY it may be underperforming (length, hook, content type) and WHAT to do. wins = top videos and patterns to repeat. IMPORTANT: ratings are often PENDING so do NOT rely on them or claim blindness. Use the underperformingVideos list, each videos ctr versus videoBenchmark.medianCtr, and videos with clicks but zero conversions. For each, name the video, cite the weak metric, predict the likely improvement if replaced, and recommend concrete fixes such as a stronger first three second hook, better length, clearer message, and call to action. healthScore reflects video creative health.',searchterms:'You are analyzing SEARCH TERM performance. priorities = wasted search terms that spent money with zero or near-zero conversions; for each, explain WHY it is wasteful and WHAT to do, and recommend the exact negative keyword to add. Group similar wasteful terms together. opportunities = high intent or converting terms worth expanding. healthScore reflects search spend efficiency.',budget:'You are analyzing BUDGET pacing and occupancy for a specific month (shown in the data). priorities = properties over budget, properties severely under-pacing their budget mid-month, and occupancy and spend mismatches; for each explain WHY and exactly WHAT to do (raise or lower daily budget, pause). Apply occupancy-based logic: recommend MORE spend for low-occupancy properties that have vacant units to fill, and LESS spend for properties near full capacity. opportunities = budget reallocation ideas between properties. wins = properties pacing well. healthScore reflects budget alignment and occupancy health together.',keywords:'You are analyzing KEYWORD performance. priorities = underperforming keywords (high spend, low or no conversions) with WHY and WHAT to do (pause, change match type, lower bid, improve landing page). wins = top converting keywords. opportunities = match type or bid adjustments and new keyword ideas. healthScore reflects keyword efficiency.'};var sys=AI_SYSTEM_PROMPT+struct+focusNote+' '+(modes[mode]||modes.overview);var userMsg='Here is the live dashboard data as JSON:\n\n'+contextJson+'\n\nRespond with ONLY the JSON object as specified.';return callClaude(sys,[{role:'user',content:userMsg}],3500);}
 
function chatWithAI(contextJson,historyJson){var sys=AI_SYSTEM_PROMPT+' You are in a live chat with the user inside their ads dashboard. Answer conversationally and concisely in markdown. Use bold for key numbers and short bullet lists. Avoid wide tables since the chat panel is narrow. Always ground answers in the real data provided and name specific properties with real numbers. Keep most answers under 140 words unless asked for more depth. After your full answer, output on a brand new final line exactly the token ___FOLLOWUPS___ immediately followed by three short specific follow-up questions the user might ask next, separated by a single pipe character, for example ___FOLLOWUPS___What should I pause first?|How is Norra pacing?|Show wasted terms. Do not put the follow-up line inside a code block. The live data the user is currently looking at as JSON: '+contextJson;var history;try{history=JSON.parse(historyJson||'[]');}catch(e){history=[];}if(!history.length)return{error:'No message provided.'};return callClaude(sys,history,1600);}
 
function getAccessToken() {
  const r = UrlFetchApp.fetch('https://oauth2.googleapis.com/token', {
    method: 'post',
    payload: { client_id: CLIENT_ID, client_secret: CLIENT_SECRET, refresh_token: REFRESH_TOKEN, grant_type: 'refresh_token' }
  });
  return JSON.parse(r.getContentText()).access_token;
}
 
function dateClause(range, cs, ce) {
  if (range === '7') return 'segments.date DURING LAST_7_DAYS';
  if (range === '30') return 'segments.date DURING LAST_30_DAYS';
  if (range === '90') {
    const end = new Date(); const start = new Date(); start.setDate(start.getDate() - 90);
    const f = function(d){ return Utilities.formatDate(d, 'GMT', 'yyyy-MM-dd'); };
    return "segments.date BETWEEN '" + f(start) + "' AND '" + f(end) + "'";
  }
  if (cs && ce) return "segments.date BETWEEN '" + cs + "' AND '" + ce + "'";
  return 'segments.date DURING LAST_30_DAYS';
}
 
function adsQuery(customerId, query, token) {
  const url = 'https://googleads.googleapis.com/' + API_VERSION + '/customers/' + customerId + '/googleAds:search';
  const r = UrlFetchApp.fetch(url, { method: 'post', headers: { 'Authorization': 'Bearer ' + token, 'developer-token': DEV_TOKEN, 'login-customer-id': MANAGER_ID, 'Content-Type': 'application/json' }, payload: JSON.stringify({ query: query }), muteHttpExceptions: true });
  const data = JSON.parse(r.getContentText());
  return data.results || [];
}
 
function getAllAccountsData(range, cs, ce) {
  range = range || '30';
  const token = getAccessToken();
  const accountsRaw = adsQuery(MANAGER_ID, 'SELECT customer_client.id, customer_client.descriptive_name, customer_client.status, customer_client.manager FROM customer_client', token);
  const accounts = accountsRaw.map(function(r){ return r.customerClient; }).filter(function(c){ return c.status === 'ENABLED' && !c.manager; });
  const dc = dateClause(range, cs, ce);
  const results = accounts.map(function(acct) {
    try {
      const camps = adsQuery(acct.id, 'SELECT campaign.name, campaign.status, metrics.impressions, metrics.clicks, metrics.cost_micros, metrics.conversions, metrics.ctr FROM campaign WHERE ' + dc + ' ORDER BY metrics.cost_micros DESC LIMIT 25', token);
      return { id: acct.id, name: acct.descriptiveName, campaigns: camps };
    } catch(e) { return { id: acct.id, name: acct.descriptiveName, campaigns: [], error: e.message }; }
  });
  return { data: results, timestamp: new Date().toISOString(), range: range };
}
 
