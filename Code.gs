'function renderBudScatter(blended){var pts=[];blended.forEach(function(o){if(o.p.occ==null)return;var col=o.flag==="OVER"?"rgba(245,90,114,0.72)":o.flag==="UNDER"?"rgba(245,177,61,0.72)":"rgba(34,211,154,0.72)";pts.push({x:Number(o.p.occ.toFixed(1)),y:Math.round(o.actual),r:8+Math.sqrt(o.p.units||1)*1.5,color:col,name:o.p.name,units:o.p.units||0,vacant:o.p.vacant||0,bud:Math.round(o.effBud)});});if(charts["bud-scatter"])charts["bud-scatter"].destroy();var ctx=document.getElementById("bud-scatter");if(!ctx)return;charts["bud-scatter"]=new Chart(ctx,{type:"bubble",data:{datasets:[{data:pts,backgroundColor:pts.map(function(p){return p.color;}),borderColor:cv("--surface"),borderWidth:1}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{backgroundColor:cv("--surface2"),titleColor:cv("--text"),bodyColor:cv("--muted2"),borderColor:cv("--border2"),borderWidth:1,padding:11,callbacks:{label:function(c){var p=pts[c.dataIndex];return [p.name,"Occupancy "+p.x+"%","Spend $"+fmt(p.y),"Budget $"+fmt(p.bud),fmt(p.vacant)+" vacant of "+fmt(p.units)+" units"];}}}},scales:{x:{title:{display:true,text:"Occupancy %",color:cv("--muted"),font:{size:11}},min:0,max:100,ticks:{color:cv("--muted"),font:{size:10,family:"JetBrains Mono"}},grid:{color:cv("--grid")}},y:{title:{display:true,text:"Monthly spend (USD)",color:cv("--muted"),font:{size:11}},ticks:{color:cv("--muted"),font:{size:10,family:"JetBrains Mono"},callback:function(v){return "$"+(v>=1000?(v/1000).toFixed(0)+"k":v);}},grid:{color:cv("--grid")}}}}});var note=document.getElementById("bud-scatter-note");if(note)note.innerHTML="Each bubble is a property, sized by unit count. The spot to watch is the <b>lower-left</b>: low occupancy and low spend means vacant units you are not advertising to fill. <b>Upper-left</b> (low occupancy, high spend) means you are actively pushing to fill, and <b>right side</b> (high occupancy) needs less budget.";}',
'function renderBudAlloc(blended){var totB=0,totV=0;blended.forEach(function(o){totB+=o.effBud;totV+=(o.p.vacant||0);});var rows=blended.filter(function(o){return o.effBud>0||(o.p.vacant||0)>0;}).map(function(o){var bs=totB>0?o.effBud/totB*100:0;var vs=totV>0?(o.p.vacant||0)/totV*100:0;var idx=vs>0?bs/vs:(bs>0?9:0);return {name:o.p.name,bs:bs,vs:vs,idx:idx,vacant:o.p.vacant||0};}).sort(function(a,b){return b.vs-a.vs;}).slice(0,16);var box=document.getElementById("bud-alloc");if(box){var h="";rows.forEach(function(r){var under=r.idx<0.6&&r.vacant>0;var over=r.idx>1.6;var col=under?"var(--amber)":over?"var(--emerald)":"var(--muted2)";var lab=under?"under-funded":over?"over-funded":"balanced";h+="<div class=\\"an-share-row\\"><div class=\\"an-share-name\\">"+r.name+"</div><div class=\\"an-share-bars\\"><div class=\\"an-sb spend\\" style=\\"width:"+Math.max(2,r.bs*3)+"px;\\" title=\\"Budget share\\"></div><div class=\\"an-sb conv\\" style=\\"width:"+Math.max(2,r.vs*3)+"px;\\" title=\\"Vacancy share\\"></div></div><div class=\\"an-share-idx\\" style=\\"color:"+col+"\\">"+r.idx.toFixed(2)+"x "+lab+"</div></div>";});box.innerHTML="<div style=\\"display:flex;gap:16px;margin-bottom:12px;font-size:11.5px;color:var(--muted);font-family:JetBrains Mono;\\"><span><span style=\\"display:inline-block;width:10px;height:10px;border-radius:3px;background:var(--accent);margin-right:5px;\\"></span>BUDGET SHARE</span><span><span style=\\"display:inline-block;width:10px;height:10px;border-radius:3px;background:var(--emerald);margin-right:5px;\\"></span>VACANCY SHARE</span></div>"+(h||"<div class=\\"empty\\">No allocation data for this month.</div>");}var under=rows.filter(function(r){return r.idx<0.6&&r.vacant>0;}).slice(0,3);var over=rows.filter(function(r){return r.idx>1.6;}).slice(0,3);var rc="";if(under.length)rc+="<div class=\\"insight amber\\"><div class=\\"insight-title\\">Under-funded vs vacancy: "+under.map(function(r){return r.name;}).join(", ")+"</div><div class=\\"insight-body