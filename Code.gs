'function aiVoiceStart(){var SR=window.SpeechRecognition||window.webkitSpeechRecognition;if(!SR){aiVoiceSetState("error");return;}try{if("speechSynthesis" in window)window.speechSynthesis.cancel();}catch(e){}voiceFinal="";try{voiceRec=new SR();}catch(e){aiVoiceSetState("error");return;}voiceRec.lang="en-US";voiceRec.interimResults=true;voiceRec.continuous=false;voiceRec.onstart=function(){aiVoiceSetState("listening");var t=document.getElementById("voiceTranscript");if(t)t.textContent="";};voiceRec.onresult=function(ev){var interim="";voiceFinal="";for(var i=0;i<ev.results.length;i++){var trx=ev.results[i][0].transcript;if(ev.results[i].isFinal)voiceFinal+=trx;else interim+=trx;}var t=document.getElementById("voiceTranscript");if(t)t.textContent=(voiceFinal||interim);};voiceRec.onerror=function(ev){if(ev.error==="not-allowed"||ev.error==="service-not-allowed"){aiVoiceSetState("error");document.getElementById("voiceStatus").textContent="Microphone is blocked";document.getElementById("voiceTranscript").textContent="Your browser blocked the mic for this page. Click the mic icon in the address bar to allow it, then tap the orb again.";}else if(ev.error==="no-speech"){aiVoiceSetState("idle");document.getElementById("voiceStatus").textContent="Did not catch that. Tap the orb to try again.";}else{aiVoiceSetState("idle");}};voiceRec.onend=function(){if(!voiceOn)return;var said=(voiceFinal||"").trim();if(said){aiVoiceAsk(said);}else if(voiceState==="listening"){aiVoiceSetState("idle");}};try{voiceRec.start();}catch(e){aiVoiceSetState("error");}}',
'function aiVoiceAsk(text){aiVoiceSetState("thinking");var tr=document.getElementById("voiceTranscript");if(tr)tr.textContent=text;var u=aiAddRow("user");u.bubble.innerHTML=aiEsc(text);aiMeta(u,"user");chatHistory.push({role:"user",content:text});var a=aiAddRow("ai");a.bubble.innerHTML="<div class=\\"ai-typing\\"><span></span><span></span><span></span></div>";aiChatScrollBottom();google.script.run.withSuccessHandler(function(r){if(r.error){aiVoiceSetState("idle");if(tr)tr.textContent=r.error;a.bubble.innerHTML="<span style=\\"color:var(--red)\\">"+r.error+"</span>";return;}var parsed=aiParseFollowups(r.text);chatHistory.push({role:"assistant",content:parsed.answer});aiTypewriter(a.bubble,aiMarkdown(parsed.answer),function(){aiMeta(a,"ai",parsed.answer);if(parsed.fu.length)aiRenderFollowups(a.col,parsed.fu);aiChatScrollBottom();});aiVoiceSpeak(parsed.answer,true);}).withFailureHandler(function(e){aiVoiceSetState("idle");if(tr)tr.textContent=e.message;a.bubble.innerHTML="<span style=\\"color:var(--red)\\">"+e.message+"</span>";}).chatWithAI(aiChatContext(),JSON.stringify(chatHistory));}',
'function aiVoiceSpeak(text,inVoiceMode){if(!("speechSynthesis" in window)){if(inVoiceMode)aiVoiceSetState("idle");return;}var clean=aiStripForSpeech(text);if(!clean){if(inVoiceMode)aiVoiceSetState("idle");return;}if(inVoiceMode){var tr=document.getElementById("voiceTranscript");if(tr)tr.textContent=clean;}try{window.speechSynthesis.cancel();}catch(e){}var ut=new SpeechSynthesisUtterance(clean);ut.lang="en-US";ut.rate=1.03;ut.pitch=1.0;var v=aiPickVoice();if(v)ut.voice=v;ut.onstart=function(){if(inVoiceMode)aiVoiceSetState("speaking");};ut.onend=function(){if(inVoiceMode){if(voiceOn&&voiceHandsFree){setTimeout(function(){if(voiceOn)aiVoiceStart();},400);}else{aiVoiceSetState("idle");}}};try{window.speechSynthesis.speak(ut);}catch(e){if(inVoiceMode)aiVoiceSetState("idle");}}',
