'function aiRenderChatEmpty(){var b=document.getElementById("chatBody");b.innerHTML="";var wrap=document.createElement("div");wrap.className="chat-empty";wrap.innerHTML="<div class=\\"chat-empty-hero\\"><div class=\\"ic\\"><svg viewBox=\\"0 0 24 24\\"><path d=\\"M12 3l1.9 5.8L20 9.7l-4.7 3.5L17 19l-5-3.4L7 19l1.7-5.8L4 9.7l6.1-.9z\\"/></svg></div><h4>How can I help?</h4><p>Ask anything about your campaigns, budgets, or creatives.</p></div>";var cats=[{c:"Spend and Budget",items:[["Which properties should I pause or cut this week?","M6 4h4v16H6zM14 4h4v16h-4z"],["Give me a budget pacing summary for this month.","M3 3v18h18M7 14l4-4 3 3 5-6"]]},{c:"Optimization",items:[["Where am I wasting search spend and what negatives should I add?","M4 6h16M7 12h10M10 18h4"],["Which properties need more budget based on occupancy?","M12 2v20M2 12h20"]]},{c:"Performance",items:[["Compare my top and bottom properties by cost per conversion.","M5 12l5 5L20 7"],["What is my best performing creative and why?","M12 2l3 7h7l-5.5 4 2 7L12 16l-6.5 5 2-7L2 9h7z"]]}];cats.forEach(function(cat){var h=document.createElement("div");h.className="chat-cat";h.textContent=cat.c;wrap.appendChild(h);cat.items.forEach(function(it){var btn=document.createElement("button");btn.className="chat-starter";btn.innerHTML="<svg viewBox=\\"0 0 24 24\\"><path d=\\""+it[1]+"\\"/></svg>";var sp=document.createElement("span");sp.textContent=it[0];btn.appendChild(sp);btn.addEventListener("click",function(){aiSendChat(it[0]);});wrap.appendChild(btn);});});b.appendChild(wrap);}',
